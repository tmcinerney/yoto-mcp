{
  "name": "yoto-mcp",
  "version": "0.5.0",
  "description": "MCP server for the Yoto API — manage MYO cards, upload audio, control devices. Multi-account support.",
  "type": "module",
  "bin": {
    "yoto-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run typecheck && npm run test",
    "prepare": "husky"
  },
  "keywords": [
    "mcp",
    "yoto",
    "yoto-player",
    "model-context-protocol",
    "audio",
    "myo-cards"
  ],
  "author": "Travers McInerney",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tmcinerney/yoto-mcp.git"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@yotoplay/yoto-sdk": "^1.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@types/node": "^25.5.0",
    "husky": "^9.1.7",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
